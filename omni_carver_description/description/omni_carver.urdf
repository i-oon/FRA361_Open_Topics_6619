<?xml version="1.0"?>
<robot name="omni_carver">
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
  <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
  <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 3.14"/>
      <geometry>
        <mesh filename="../mesh/twheel_base.STL"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 0.5 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1208" ixy="0.0" ixz="0.0" iyy="0.1208" iyz="0.0" izz="0.2083"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"/>    
  </joint>

  <link name="wheel_1_link">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>           
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000879" ixy="0.0" ixz="0.0" iyy="0.000879" iyz="0.0" izz="0.001406"/>
    </inertial>
  </link>

  <joint name="wheel_1_joint" type="continuous">
    <origin xyz="0.150 -0.250 -0.075" rpy="1.57 0.0 0.52"/>
    <parent link="base_link"/>
    <child link="wheel_1_link"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <link name="wheel_2_link">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>         
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000879" ixy="0.0" ixz="0.0" iyy="0.000879" iyz="0.0" izz="0.001406"/>
    </inertial>
  </link>

  <joint name="wheel_2_joint" type="continuous">
    <origin xyz="0.145 0.250 -0.075" rpy="-1.57 0.0 -0.52"/>
    <parent link="base_link"/>
    <child link="wheel_2_link"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <link name="wheel_3_link">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.075" length="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000879" ixy="0.0" ixz="0.0" iyy="0.000879" iyz="0.0" izz="0.001406"/>
    </inertial>
  </link>

  <joint name="wheel_3_joint" type="continuous">
    <origin xyz="-0.295 0.0 -0.075" rpy="0.0 -1.57 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_3_link"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <link name="laser_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.035"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000235" ixy="0.0" ixz="0.0" iyy="0.0000235" iyz="0.0" izz="0.0000267"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="-0.023 0 0.36" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000000833" ixy="0.0" ixz="0.0" iyy="0.000000833" iyz="0.0" izz="0.000000833"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.21 0 0.1285" rpy="0.0 0.0 0.0"/>
  </joint>

</robot>