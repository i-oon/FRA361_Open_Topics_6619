<mujoco model="omni_carver">
  <compiler angle="radian" meshdir="../mesh" autolimits="true"/>
  
  <option timestep="0.002" gravity="0 0 -9.81">
    <flag contact="enable"/>
  </option>
  
  <asset>
    <mesh name="base_mesh" file="twheel_base.STL"/>
  </asset>
  
  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="20 20 0.1" rgba="0.9 0.9 0.9 1" friction="0.5 0.005 0.0001"/>
    
    <body name="base_link" pos="0 0 0.15">
      <freejoint name="base_freejoint"/>
      <geom name="base_visual" type="mesh" mesh="base_mesh" euler="0 0 3.14" rgba="1 1 1 1"/>
      <geom name="base_collision" type="cylinder" size="0.25 0.1" rgba="0.3 0.5 0.7 0.3" group="3"/>
      <inertial pos="0 0 0" mass="5.0" diaginertia="0.1208 0.1208 0.2083"/>
      
      <body name="wheel_1" pos="0.150 -0.250 -0.075" euler="1.57 0.0 0.52">
        <joint name="wheel_1_joint" type="hinge" axis="0 0 1" damping="0.1"/>
        <geom type="cylinder" size="0.075 0.0325" rgba="0 0 1 1"/>
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.000879 0.000879 0.001406"/>
      </body>
      
      <body name="wheel_2" pos="0.145 0.250 -0.075" euler="-1.57 0.0 -0.52">
        <joint name="wheel_2_joint" type="hinge" axis="0 0 1" damping="0.1"/>
        <geom type="cylinder" size="0.075 0.0325" rgba="1 0 0 1"/>
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.000879 0.000879 0.001406"/>
      </body>
      
      <body name="wheel_3" pos="-0.295 0.0 -0.075" euler="0.0 -1.57 0.0">
        <joint name="wheel_3_joint" type="hinge" axis="0 0 1" damping="0.1"/>
        <geom type="cylinder" size="0.075 0.0325" rgba="0 1 0 1"/>
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.000879 0.000879 0.001406"/>
      </body>
      
      <body name="laser" pos="-0.023 0 0.36">
        <geom type="box" size="0.02 0.02 0.0175" rgba="0 0 0 1"/>
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.0000235 0.0000235 0.0000267"/>
      </body>
      
      <body name="imu" pos="-0.21 0 0.1285">
        <geom type="box" size="0.005 0.005 0.005" rgba="0.5 0.5 0.5 1"/>
        <inertial pos="0 0 0" mass="0.05" diaginertia="0.000000833 0.000000833 0.000000833"/>
      </body>
    </body>
  </worldbody>
  
  <actuator>
    <!-- Increase control range for faster movement -->
    <velocity name="vx" joint="base_freejoint" kv="150" 
              gear="1 0 0 0 0 0" ctrlrange="-2.0 2.0"/>
    <velocity name="vy" joint="base_freejoint" kv="150" 
              gear="0 1 0 0 0 0" ctrlrange="-2.0 2.0"/>
    <velocity name="wz" joint="base_freejoint" kv="30" 
              gear="0 0 0 0 0 1" ctrlrange="-3.0 3.0"/>
  </actuator>
</mujoco>